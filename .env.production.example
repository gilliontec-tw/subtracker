# === SubTrack Production Environment ===
# Copy to .env and fill in <...> placeholders

# PostgreSQL
POSTGRES_USER=subtrack
POSTGRES_PASSWORD=<openssl rand -hex 16>
POSTGRES_DB=subtrack

# Database (internal docker network)
DATABASE_URL=postgresql+asyncpg://subtrack:<SAME_PASSWORD>@db:5432/subtrack

# Redis (internal docker network)
REDIS_URL=redis://redis:6379/0

# JWT (generate each: openssl rand -hex 32)
JWT_ACCESS_SECRET_KEY=<GENERATE>
JWT_REFRESH_SECRET_KEY=<GENERATE>
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# CORS — 必須與用戶瀏覽器的 URL 完全一致
CORS_ORIGINS=http://192.168.1.7

# SMTP
SMTP_HOST=pollux4.url.com.tw
SMTP_PORT=587
SMTP_USER=service@gilliontec.com.tw
SMTP_PASSWORD=<SMTP_PASSWORD>
SMTP_FROM=service@gilliontec.com.tw

# App
APP_ENV=production
APP_URL=http://192.168.1.7

# Notification scheduler
NOTIFICATION_CRON_HOUR=8
NOTIFICATION_CRON_MINUTE=0
