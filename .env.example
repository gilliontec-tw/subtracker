# SQL Server - Windows Authentication (same machine or domain)
DB_CONNECTION_STRING=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};Server=YOUR_SERVER;Database=subtrack;Trusted_Connection=yes

# SQL Server - SQL Authentication (cross-machine)
# DB_CONNECTION_STRING=mssql+pyodbc://saas_app:YOUR_PASSWORD@YOUR_SERVER/subtrack?driver=ODBC+Driver+17+for+SQL+Server

# SMTP Settings
SMTP_HOST=your-smtp-server
SMTP_PORT=465
SMTP_USERNAME=your-email@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@your-domain.com

# Web Server (0.0.0.0 makes it reachable by LAN IP, not just localhost)
APP_HOST=0.0.0.0
APP_PORT=8000
