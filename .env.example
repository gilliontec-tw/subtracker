# SQL Server - Windows Authentication (same machine or domain)
DB_CONNECTION_STRING=mssql+pyodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};Server=YOUR_SERVER;Database=saas_tracker;Trusted_Connection=yes

# SQL Server - SQL Authentication (cross-machine)
# DB_CONNECTION_STRING=mssql+pyodbc://sa:YOUR_PASSWORD@YOUR_SERVER/saas_tracker?driver=ODBC+Driver+17+for+SQL+Server

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# Web Server (0.0.0.0 makes it reachable by LAN IP, not just localhost)
APP_HOST=0.0.0.0
APP_PORT=8000
